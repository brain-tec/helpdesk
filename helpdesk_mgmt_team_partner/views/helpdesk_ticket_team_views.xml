<odoo>
    <record id="helpdesk_team_form_inherit_team_customer" model="ir.ui.view">
        <field name="name">
            view.helpdesk_ticket_team.form.team.customer (in helpdesk_mgmt_team_customer)
        </field>
        <field name="model">helpdesk.ticket.team</field>
        <field name="inherit_id" ref="helpdesk_mgmt.view_helpdesk_team_form" />
        <field name="arch" type="xml">
            <xpath expr="//notebook/page" position="after">
                <page name="partners" string="Associated Partners">
                    <group>
                        <field name="default_partner_id" />
                        <field
                            name="is_unique_partner"
                            readonly="default_partner_id == False"
                            widget="boolean_toggle"
                        />
                        <field
                            name="allowed_partner_ids"
                            readonly="is_unique_partner == True"
                            widget="many2many_tags"
                        />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
