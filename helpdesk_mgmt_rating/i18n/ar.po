#. module: helpdesk_mgmt_rating
#: model:mail.template,body_html:helpdesk_mgmt_rating.rating_ticket_email_template
msgid ""
"<div>\n"
"                <t t-set=\"access_token\" t-value=\"object._rating_get_access_token()\"/>\n"
"                <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" style=\"width:100%; margin:0px auto;\">\n"
"                    <tbody>\n"
"                        <tr>\n"
"                            <td style=\"padding:15px 20px 10px 20px;\">\n"
"                                <p>Hello,</p>\n"
"                                <p>Please take a moment to rate our services related to the ticket \"<strong><t t-out=\"object.number\"/> - <t t-out=\"object.name\"/></strong>\"assigned to <strong>\n"
"                                    <t t-out=\"object._rating_get_operator().name\"/>\n"
"                                </strong>.</p>\n"
"                                <p>We appreciate your feedback. It helps us to improve continuously.</p>\n"
"                            </td>\n"
"                        </tr>\n"
"                        <tr>\n"
"                            <td style=\"padding:10px 20px\">\n"
"                                <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" summary=\"o_mail_notification\" style=\"width:100%; margin: 32px 0px 32px 0px;\">\n"
"                                    <tr>\n"
"                                        <td style=\"text-align:center;\">\n"
"                                            <h2 style=\"font-weight:300;font-size:18px;\">Tell us how you feel about our service:</h2>\n"
"                                            <div style=\"text-color: #888888\">(click on one of these smileys)</div>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                    <tr>\n"
"                                        <td style=\"padding:10px 10px;\">\n"
"                                            <table style=\"width:100%;text-align:center;margin-top:2rem;\">\n"
"                                                <tr>\n"
"                                                    <td>\n"
"                                                        <a t-attf-href=\"/rate/{{ access_token }}/5\">\n"
"                                                            <img alt=\"Satisfied\" src=\"/rating/static/src/img/rating_5.png\" title=\"Satisfied\"/>\n"
"                                                        </a>\n"
"                                                    </td>\n"
"                                                    <td>\n"
"                                                        <a t-attf-href=\"/rate/{{ access_token }}/3\">\n"
"                                                            <img alt=\"Not satisfied\" src=\"/rating/static/src/img/rating_3.png\" title=\"Not satisfied\"/>\n"
"                                                        </a>\n"
"                                                    </td>\n"
"                                                    <td>\n"
"                                                        <a t-attf-href=\"/rate/{{ access_token }}/1\">\n"
"                                                            <img alt=\"Highly Dissatisfied\" src=\"/rating/static/src/img/rating_1.png\" title=\"Highly Dissatisfied\"/>\n"
"                                                        </a>\n"
"                                                    </td>\n"
"                                                </tr>\n"
"                                            </table>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </table>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"                <table style=\"width:600px;margin:auto;text-align:center;font-size:12px;\">\n"
"                    <tbody>\n"
"                        <tr>\n"
"                            <td style=\"padding-top:10px;color:#afafaf;\">\n"
"                                <t t-if=\"object.rating_status == 'stage_change'\">\n"
"                                    <p>This customer survey has been sent because your ticket has been moved to the stage <b t-out=\"object.stage_id.name\"/></p>\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        "
msgstr ""
"<div>\n"
"                <t t-set=\"access_token\" t-"
"value=\"object._rating_get_access_token()\"/>\n"
"                <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" "
"width=\"590\" style=\"width:100%; margin:0px auto;\">\n"
"                    <tbody>\n"
"                        <tr>\n"
"                            <td style=\"padding:15px 20px 10px 20px;\">\n"
"                                <p>مرحباً،</p>\n"
"                                <p>يرجى أخذ لحظة لتقييم خدماتنا المتعلقة "
"بالطلب \"<strong><t t-out=\"object.number\"/> - <t t-out=\"object.name\"/></"
"strong>\"المسندة إلى <strong>\n"
"                                    <t t-out=\"object._rating_get_operator()"
".name\"/>\n"
"                                </strong>.</p>\n"
"                                <p>نحن نقدر ملاحظاتك. فهي تساعدنا على التحسين "
"المستمر.</p>\n"
"                            </td>\n"
"                        </tr>\n"
"                        <tr>\n"
"                            <td style=\"padding:10px 20px\">\n"
"                                <table border=\"0\" cellpadding=\"0\" "
"cellspacing=\"0\" width=\"590\" summary=\"o_mail_notification\" "
"style=\"width:100%; margin: 32px 0px 32px 0px;\">\n"
"                                    <tr>\n"
"                                        <td style=\"text-align:center;\">\n"
"                                            <h2 style=\"font-weight:300;font-"
"size:18px;\">أخبرنا عن رأيك في خدمتنا:</h2>\n"
"                                            <div style=\"text-color: "
"#888888\">(انقر على أحد هذه الوجوه التعبيرية)</div>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                    <tr>\n"
"                                        <td style=\"padding:10px 10px;\">\n"
"                                            <table style=\"width:100%;text-"
"align:center;margin-top:2rem;\">\n"
"                                                <tr>\n"
"                                                    <td>\n"
"                                                        <a t-attf-href=\"/"
"rate/{{ access_token }}/5\">\n"
"                                                            <img alt=\"راضٍ\" "
"src=\"/rating/static/src/img/rating_5.png\" title=\"راضٍ\"/>\n"
"                                                        </a>\n"
"                                                    </td>\n"
"                                                    <td>\n"
"                                                        <a t-attf-href=\"/"
"rate/{{ access_token }}/3\">\n"
"                                                            <img alt=\"غير "
"راضٍ\" src=\"/rating/static/src/img/rating_3.png\" title=\"غير راضٍ\"/>\n"
"                                                        </a>\n"
"                                                    </td>\n"
"                                                    <td>\n"
"                                                        <a t-attf-href=\"/"
"rate/{{ access_token }}/1\">\n"
"                                                            <img alt=\"غير "
"راضٍ جداً\" src=\"/rating/static/src/img/rating_1.png\" title=\"غير راضٍ جداً\"/>"
"\n"
"                                                        </a>\n"
"                                                    </td>\n"
"                                                </tr>\n"
"                                            </table>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </table>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"                <table style=\"width:600px;margin:auto;text-"
"align:center;font-size:12px;\">\n"
"                    <tbody>\n"
"                        <tr>\n"
"                            <td style=\"padding-top:10px;color:#afafaf;\">\n"
"                                <t t-if=\"object.rating_status == "
"'stage_change'\">\n"
"                                    <p>تم إرسال هذا الاستبيان للعميل لأن "
"تذكرتك تم نقلها إلى المرحلة <b t-out=\"object.stage_id.name\"/></p>\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        "

